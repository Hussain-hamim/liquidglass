{
	"name": "liquid-glass",
	"version": "1.0.0",
	"description": "A liquid glass effect library for the web — apply realistic glass refraction, blur, and lighting to any HTML element.",
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist/",
		"src/"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch"
	},
	"keywords": [
		"liquid-glass",
		"glass",
		"effect",
		"webgl",
		"shader",
		"blur",
		"refraction",
		"ui"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"html-to-image": "^1.11.11"
	},
	"devDependencies": {
		"typescript": "^5.7.0"
	}
}
